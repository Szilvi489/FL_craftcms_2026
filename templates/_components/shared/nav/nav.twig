{% set layout = navLayout|default('full') %}
{% set contactHref = navContactHref|default('') %}

<nav class="site-nav site-nav--layout-{{ layout }} site-nav--theme-{{ navTheme|default('black') }} site-nav--behavior-{{ navBehavior|default('static') }}" aria-label="Primary">
  {% if navBackHref is defined and navBackHref %}
    <a class="site-nav__link site-back-link" href="{{ navBackHref }}">
      <span class="site-back-link__icon" aria-hidden="true">
        <svg class="site-back-link__icon-svg" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.5 6.5 8.5 12l6 5.5" fill="none" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.75"/>
          <path d="M9 12h8.5" fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="1.75"/>
        </svg>
      </span>
      <span class="site-back-link__label">back</span>
    </a>
  {% endif %}
  {% if layout == 'contact' %}
    <a class="site-home-link site-nav__link" href="{{ siteUrl }}#home-reveal" aria-label="Home">FL</a>
    {% if contactHref %}
      <a
        class="site-nav__link site-contact-toggle"
        href="{{ contactHref }}"
        aria-label="Send email"
        title="Send email"
      >
        <span class="site-contact-toggle__frame" aria-hidden="true">
          <svg class="site-contact-toggle__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7.5h16v9H4z" fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="1"/>
            <path d="m4.5 8 7.5 6 7.5-6" fill="none" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1"/>
          </svg>
        </span>
      </a>
    {% endif %}
  {% else %}
  {% if layout not in ['home-only', 'fl-fullscreen'] %}
    <a class="site-nav__link" href="/index">Index</a>
    <button class="site-nav__link site-nav__button site-panel-toggle" type="button" aria-expanded="false" aria-controls="site-info-panel">
      Info
    </button>
    <a class="site-nav__link" href="/contact">
      Contact
    </a>
  {% endif %}
  <a class="site-home-link site-nav__link" href="{{ siteUrl }}#home-reveal" aria-label="Home">FL</a>
  {% if layout == 'fl-fullscreen' %}
    <button class="site-nav__button site-fullscreen-toggle" type="button" aria-pressed="false" aria-label="Enter fullscreen" title="Enter fullscreen">
      <span class="site-fullscreen-toggle__frame" aria-hidden="true">
        <svg class="site-fullscreen-toggle__icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 9V3h6M21 9V3h-6M3 15v6h6M21 15v6h-6" fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="0.8"/>
        </svg>
        <svg class="site-fullscreen-toggle__plus" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 7v10M7 12h10" fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="1.1"/>
        </svg>
      </span>
    </button>
  {% endif %}
  {% if layout not in ['home-only', 'fl-fullscreen'] %}
  <a class="site-nav__link" href="/shop">Shop</a>
        <button class="site-nav__button site-fullscreen-toggle site-fullscreen-toggle--inline" type="button" aria-pressed="false" aria-label="Enter fullscreen" title="Enter fullscreen">
        <span class="site-fullscreen-toggle__frame" aria-hidden="true">
          <svg class="site-fullscreen-toggle__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 9V3h6M21 9V3h-6M3 15v6h6M21 15v6h-6" fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="0.8"/>
          </svg>
          <svg class="site-fullscreen-toggle__plus" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 7v10M7 12h10" fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="1.1"/>
          </svg>
        </span>
      </button>
    <div class="site-nav__legal">
      <button class="site-nav__link site-nav__button site-panel-toggle" type="button" aria-expanded="false" aria-controls="site-imprint-panel">
        Imprint
      </button>
      <span class="site-nav__separator" aria-hidden="true">/</span>
      <button class="site-nav__link site-nav__button site-panel-toggle" type="button" aria-expanded="false" aria-controls="site-privacy-panel">
        Privacy
      </button>
    </div>
  {% endif %}
  {% endif %}
</nav>

<section class="site-info-panel" id="site-info-panel" aria-hidden="true">
  <div class="site-info-panel__inner">
    {% include "_components/info.twig" %}
  </div>
</section>

<section class="site-imprint-panel" id="site-imprint-panel" aria-hidden="true">
  <div class="site-imprint-panel__inner">
    {% include "_components/imprint.twig" %}
  </div>
</section>

<section class="site-privacy-panel" id="site-privacy-panel" aria-hidden="true">
  <div class="site-privacy-panel__inner">
    {% include "_components/privacy.twig" %}
  </div>
</section>
