{% extends "_layouts/main.twig" %}

{% set homeEntry = null %}
{% if currentUser %}
  {% set homeEntry = craft.entries()
    .section('homepage')
    .site(currentSite)
    .status(null)
    .draftOf(false)
    .savedDraftsOnly()
    .draftCreator(currentUser)
    .orderBy('elements.dateUpdated DESC')
    .one() %}
{% endif %}
{% if not homeEntry %}
  {% set homeEntry = craft.entries().section('homepage').site(currentSite).one() %}
{% endif %}
{% block navBehavior %}home-reveal{% endblock %}

{% block pageStyles %}
  <link rel="stylesheet" href="/css/index/indexStyle.css?v=12">
{% endblock %}

{% block pageScripts %}
  <script src="/js/vendor/gsap.min.js"></script>
  <script src="/js/vendor/ScrollTrigger.min.js"></script>
  <script src="/js/index/indexHero.js?v=12"></script>
{% endblock %}

{% block content %}
{% set indexImage = homeEntry ? homeEntry.indexImage.one() : null %}
{% set coverHoleTop = homeEntry and homeEntry.coverHoleTop ? homeEntry.coverHoleTop : '12vh' %}
{% set coverHoleLeft = homeEntry and homeEntry.coverHoleLeft ? homeEntry.coverHoleLeft : '55vw' %}
{% set coverHoleSizeWidth = homeEntry and homeEntry.coverHoleSizeWidth ? homeEntry.coverHoleSizeWidth : '18vw' %}


<section
  class="home-hero{% if indexImage %} home-hero--has-image{% endif %}"
  style="--home-cover-hole-top: {{ coverHoleTop|e('html_attr') }}; --home-cover-hole-left: {{ coverHoleLeft|e('html_attr') }}; --home-cover-hole-size: {{ coverHoleSizeWidth|e('html_attr') }};"
>
  {% if indexImage %}
    <div class="home-hero__media">
      <img
        src="{{ indexImage.url }}"
        alt="{{ indexImage.title ?: siteName }}"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {% endif %}

  <div
    class="home-hero__cover"
    aria-hidden="true"
  >
    <div class="home-hero__hole"></div>
  </div>

  <div class="intro-title">
    <h1>{{ siteName }}</h1>
    <h2>Photography</h2>
  </div>
</section>

{% endblock %}
