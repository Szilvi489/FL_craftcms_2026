{% set mediaTypeField = attribute(card, 'mediaType') %}
{% set mediaType = mediaTypeField.value ?? mediaTypeField ?? null %}
{% set media = null %}
{% set speed = attribute(card, 'multiImageSpeed') ?? null %}
{% set meta = [attribute(card, 'client') ?? null, attribute(card, 'projectType') ?? null]|filter %}
{% set linkedProject = null %}
{% set cardImageSmall = { width: 640, quality: 68 } %}
{% set cardImageMedium = { width: 960, quality: 70 } %}
{% set cardImageLarge = { width: 1280, quality: 72 } %}
{% set cardImageSizes = '(max-width: 767px) 88vw, (max-width: 1199px) 46vw, 30vw' %}

{% if not attribute(card, 'isFieldEmpty', ['linkedProject'], 'method') %}
  {% set linkedProjectField = attribute(card, 'getFieldValue', ['linkedProject'], 'method') %}
  {% set linkedProject = linkedProjectField ? linkedProjectField.one() : null %}
{% endif %}

{% if mediaType == 'singleImage' %}
  {% set mediaField = attribute(card, 'singleImage') %}
  {% set media = mediaField ? mediaField.one() : null %}
{% elseif mediaType == 'multiImage' %}
  {% set mediaField = attribute(card, 'multiImage') %}
  {% set media = mediaField ? mediaField.all() : [] %}
{% elseif mediaType == 'video' %}
  {% set mediaField = attribute(card, 'video') %}
  {% set media = mediaField ? mediaField.one() : null %}
{% elseif mediaType == 'gif' %}
  {% set mediaField = attribute(card, 'gif') %}
  {% set media = mediaField ? mediaField.one() : null %}
{% endif %}

<article class="home-work-card" data-home-work-card data-media-type="{{ mediaType ?: '' }}">
  {% if linkedProject %}
    <a class="home-work-card__media-link" href="{{ linkedProject.url }}">
  {% endif %}
    <div class="home-work-card__media">
      {% if mediaType == 'multiImage' and media %}
        <div
          class="home-work-card__slideshow"
          data-home-card-slideshow
          data-home-card-speed="{{ speed ?: 1600 }}"
        >
          {% for asset in media %}
            <img
              class="home-work-card__slide{% if loop.first %} is-active{% endif %}"
              data-home-card-frame
              src="{{ asset.getUrl(cardImageMedium) }}"
              srcset="{{ asset.getUrl(cardImageSmall) }} 640w, {{ asset.getUrl(cardImageMedium) }} 960w, {{ asset.getUrl(cardImageLarge) }} 1280w"
              sizes="{{ cardImageSizes }}"
              alt="{{ asset.title ?: card.title }}"
              loading="lazy"
              decoding="async"
            >
          {% endfor %}
        </div>
      {% elseif mediaType == 'video' and media %}
        <video
          data-home-card-video
          src="{{ media.url }}"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        ></video>
      {% elseif mediaType == 'gif' and media %}
        <img
          src="{{ media.url }}"
          alt="{{ media.title ?: card.title }}"
          loading="lazy"
          decoding="async"
        >
      {% elseif media %}
        <img
          src="{{ media.getUrl(cardImageMedium) }}"
          srcset="{{ media.getUrl(cardImageSmall) }} 640w, {{ media.getUrl(cardImageMedium) }} 960w, {{ media.getUrl(cardImageLarge) }} 1280w"
          sizes="{{ cardImageSizes }}"
          alt="{{ media.title ?: card.title }}"
          loading="lazy"
          decoding="async"
        >
      {% endif %}
    </div>
  {% if linkedProject %}
    </a>
  {% endif %}

  <div class="home-work-card__text">
    <h3>{{ card.title }}</h3>
    {% if meta %}
      <p>{{ meta|join(', ') }}</p>
    {% endif %}
  </div>
</article>
