{% extends "_layouts/main.twig" %}

{% set contactEntry = null %}
{% if currentUser %}
  {% set contactEntry = craft.entries()
    .section('contactpage')
    .site(currentSite)
    .status(null)
    .draftOf(false)
    .savedDraftsOnly()
    .draftCreator(currentUser)
    .orderBy('elements.dateUpdated DESC')
    .one() %}
{% endif %}
{% if not contactEntry %}
  {% set contactEntry = craft.entries().section('contactpage').site(currentSite).one() %}
{% endif %}

{% block barbaNamespace %}contact{% endblock %}
{% block title %}{{ contactEntry and contactEntry.title ? contactEntry.title : 'Contact' }} - {{ siteName }}{% endblock %}

{% block content %}
  {% include "_components/contact.twig" with {
    contactEntry: contactEntry,
    contactSubmission: submission ?? null
  } %}
{% endblock %}
