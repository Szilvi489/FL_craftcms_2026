{% extends "_layouts/main.twig" %}

{% block navLayout %}fl-fullscreen{% endblock %}
{% block navTheme %}dynamic-inverse{% endblock %}
{% block title %}Index - {{ siteName }}{% endblock %}

{% block pageStyles %}
  <link rel="stylesheet" href="/css/index/index.css?v=9">
{% endblock %}

{% block pageScripts %}
  <script src="/js/index/indexPage.js?v=4"></script>
{% endblock %}

{% block content %}
{% set indexEntry = entry is defined and entry.section is defined and entry.section.handle == 'indexPage' ? entry : null %}
{% if not indexEntry and currentUser %}
  {% set indexEntry = craft.entries()
    .section('indexPage')
    .site(currentSite)
    .status(null)
    .draftOf(false)
    .savedDraftsOnly()
    .draftCreator(currentUser)
    .orderBy('elements.dateUpdated DESC')
    .one() %}
{% endif %}
{% if not indexEntry %}
  {% set indexEntry = craft.entries().section('indexPage').site(currentSite).one() %}
{% endif %}
{% set initialBackgroundMedia = indexEntry ? indexEntry.initialBackgroundMedia.one() : null %}
{% set projects = craft.entries.section('projects').orderBy('projectYear desc, title asc').all() %}

<section class="projects-index">
  <div class="projects-index__desktop">
    <div class="projects-index__background" aria-hidden="true"{% if initialBackgroundMedia %} data-default-preview-key="initial-background"{% endif %}>
      {% if initialBackgroundMedia %}
        <div class="projects-index__background-item is-active" data-preview-key="initial-background">
          {% if initialBackgroundMedia.kind == 'video' %}
            <video
              src="{{ initialBackgroundMedia.url }}"
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
          {% else %}
            <img src="{{ initialBackgroundMedia.url }}" alt="">
          {% endif %}
        </div>
      {% endif %}
      {% for project in projects %}
        {% set previewMedia = project.heroImage.one() %}
        {% if not previewMedia and project.projectBlocks is defined %}
          {% set firstImageBlock = project.projectBlocks.type('imageBlock').one() %}
          {% set previewMedia = firstImageBlock ? firstImageBlock.blockImage.one() : null %}
        {% endif %}

        {% if previewMedia %}
          <div class="projects-index__background-item" data-preview-key="project-{{ project.id }}">
            {% if previewMedia.kind == 'video' %}
              <video
                src="{{ previewMedia.url }}"
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            {% else %}
              <img src="{{ previewMedia.url }}" alt="">
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="projects-index__content">
      <div class="project-list" aria-label="Projects">
        <div class="project-list__header" aria-hidden="true">
          <span>Title</span>
          <span>Genre</span>
          <span>Client</span>
          <span>Year</span>
        </div>

        {% for project in projects %}
          {% set previewMedia = project.heroImage.one() %}
          {% if not previewMedia and project.projectBlocks is defined %}
            {% set firstImageBlock = project.projectBlocks.type('imageBlock').one() %}
            {% set previewMedia = firstImageBlock ? firstImageBlock.blockImage.one() : null %}
          {% endif %}

          <a
            class="project-row"
            href="/{{ project.uri }}"
            {% if previewMedia %}data-preview-key="project-{{ project.id }}"{% endif %}
          >
            <span>{{ project.title }}</span>
            <span>{{ project.projectType ?: '' }}</span>
            <span>{{ project.client ?: '' }}</span>
            <span>{{ project.projectYear ?: '' }}</span>
          </a>
        {% else %}
          <p>No projects have been added yet.</p>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="projects-index__mobile" aria-label="Projects">
    <div class="projects-index__mobile-background" aria-hidden="true"{% if initialBackgroundMedia %} data-default-preview-key="initial-background"{% endif %}>
      {% if initialBackgroundMedia %}
        <div class="projects-index__mobile-background-item is-active" data-preview-key="initial-background">
          {% if initialBackgroundMedia.kind == 'video' %}
            <video
              src="{{ initialBackgroundMedia.url }}"
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
          {% else %}
            <img src="{{ initialBackgroundMedia.url }}" alt="">
          {% endif %}
        </div>
      {% endif %}
      {% for project in projects %}
        {% set previewMedia = project.heroImage.one() %}
        {% if not previewMedia and project.projectBlocks is defined %}
          {% set firstImageBlock = project.projectBlocks.type('imageBlock').one() %}
          {% set previewMedia = firstImageBlock ? firstImageBlock.blockImage.one() : null %}
        {% endif %}

        {% if previewMedia %}
          <div class="projects-index__mobile-background-item" data-preview-key="project-{{ project.id }}">
            {% if previewMedia.kind == 'video' %}
              <video
                src="{{ previewMedia.url }}"
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            {% else %}
              <img src="{{ previewMedia.url }}" alt="">
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% for project in projects %}
      {% set previewMedia = project.heroImage.one() %}
      {% if not previewMedia and project.projectBlocks is defined %}
        {% set firstImageBlock = project.projectBlocks.type('imageBlock').one() %}
        {% set previewMedia = firstImageBlock ? firstImageBlock.blockImage.one() : null %}
      {% endif %}

      <a
        class="project-mobile-card"
        href="/{{ project.uri }}"
        {% if previewMedia %}data-preview-key="project-{{ project.id }}"{% endif %}
      >
        {% if previewMedia %}
          <div class="project-mobile-card__frame" aria-hidden="true">
            <div class="project-mobile-card__inset">
              {% if previewMedia.kind == 'video' %}
                <video
                  src="{{ previewMedia.url }}"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                ></video>
              {% else %}
                <img src="{{ previewMedia.url }}" alt="">
              {% endif %}
            </div>

            {% if project.client or project.projectYear %}
              <div class="project-mobile-card__meta">
                {% if project.client %}
                  <span>{{ project.client }}</span>
                {% endif %}
                {% if project.projectYear %}
                  <span>{{ project.projectYear }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}

        <h2 class="project-mobile-card__title">{{ project.title }}</h2>
      </a>
    {% else %}
      <p>No projects have been added yet.</p>
    {% endfor %}
  </div>
</section>
{% endblock %}
