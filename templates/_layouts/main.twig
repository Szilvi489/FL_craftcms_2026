<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
{% set transitionHomeEntry = null %}
{% if currentUser %}
  {% set transitionHomeEntry = craft.entries()
    .section('homepage')
    .site(currentSite)
    .status(null)
    .draftOf(false)
    .savedDraftsOnly()
    .draftCreator(currentUser)
    .orderBy('elements.dateUpdated DESC')
    .one() %}
{% endif %}
{% if not transitionHomeEntry %}
  {% set transitionHomeEntry = craft.entries().section('homepage').site(currentSite).one() %}
{% endif %}
{% set transitionHoleTop = transitionHomeEntry and transitionHomeEntry.coverHoleTop ? transitionHomeEntry.coverHoleTop : '12vh' %}
{% set transitionHoleLeft = transitionHomeEntry and transitionHomeEntry.coverHoleLeft ? transitionHomeEntry.coverHoleLeft : '55vw' %}
{% set transitionHoleSize = transitionHomeEntry and transitionHomeEntry.coverHoleSizeWidth ? transitionHomeEntry.coverHoleSizeWidth : '18vw' %}
{% set pageBodyClass %}{% block bodyClass %}{% endblock %}{% endset %}
{% set barbaNamespace %}{% block barbaNamespace %}default{% endblock %}{% endset %}
{% set navTheme %}{% block navTheme %}black{% endblock %}{% endset %}
{% set navLayout %}{% block navLayout %}full{% endblock %}{% endset %}
{% set navBehavior %}{% block navBehavior %}static{% endblock %}{% endset %}
{% set navBackHref %}{% block navBackHref %}{% endblock %}{% endset %}
{% set navContactHref %}{% block navContactHref %}{% endblock %}{% endset %}
{% set navContactToggleExpanded %}{% block navContactToggleExpanded %}false{% endblock %}{% endset %}
<head>
    <meta charset="utf-8">
    <title>{% block title %}{{ siteName }}{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/base/variables.css?v=2">
    <link rel="stylesheet" href="/css/base/reset.css">
    <link rel="stylesheet" href="/css/base/base.css?v=6">
    <link rel="stylesheet" href="/css/base/typography.css">
    <link rel="stylesheet" href="/css/nav/nav.css?v=30">
    <link rel="stylesheet" href="/css/info/info.css?v=3">
    <link rel="stylesheet" href="/css/contact/contact.css?v=13">
    <link rel="stylesheet" href="/css/legal/legal.css?v=4">
    <link rel="stylesheet" href="/css/transition/transition.css?v=8">
    <link rel="stylesheet" href="/css/home/home.css?v=7">
    <link rel="stylesheet" href="/css/index/index.css?v=23">
    <link rel="stylesheet" href="/css/404/404.css?v=3">
    <link rel="stylesheet" href="/css/project/project.css?v=10">
    <link rel="stylesheet" href="/css/styles.css?v=2">
    {% block pageStyles %}{% endblock %}
</head>
<body
  data-barba="wrapper"
  class="{{ pageBodyClass|trim }}"
  style="--page-transition-hole-top: {{ transitionHoleTop|e('html_attr') }}; --page-transition-hole-left: {{ transitionHoleLeft|e('html_attr') }}; --page-transition-hole-size: {{ transitionHoleSize|e('html_attr') }};"
>
    <div
      class="site-page-shell"
      data-barba="container"
      data-barba-namespace="{{ barbaNamespace|trim ?: 'default' }}"
    >
      {% include "_components/shared/nav/nav.twig" with {
        navLayout: navLayout|trim ?: 'full',
        navTheme: navTheme|trim ?: 'black',
        navBehavior: navBehavior|trim ?: 'static',
        navBackHref: navBackHref|trim,
        navContactHref: navContactHref|trim,
        navContactToggleExpanded: navContactToggleExpanded|trim == 'true'
      } %}

      <main class="site-main">
          {% block content %}{% endblock %}
      </main>
    </div>

    <div class="page-transition" aria-hidden="true">
      <div class="page-transition__window">
        <span class="page-transition__mask page-transition__mask--top"></span>
        <span class="page-transition__mask page-transition__mask--right"></span>
        <span class="page-transition__mask page-transition__mask--bottom"></span>
        <span class="page-transition__mask page-transition__mask--left"></span>
      </div>
    </div>

    <div class="site-cursor" aria-hidden="true"></div>

    <script src="/js/vendor/gsap.min.js"></script>
    <script src="/js/vendor/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@barba/core"></script>
    {% block pageScripts %}{% endblock %}
    <script type="module" src="/js/app.js?v=46"></script>
</body>
</html>
