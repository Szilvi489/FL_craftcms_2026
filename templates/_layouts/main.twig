<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
{% set transitionHomeEntry = null %}
{% if currentUser %}
  {% set transitionHomeEntry = craft.entries()
    .section('homepage')
    .site(currentSite)
    .status(null)
    .draftOf(false)
    .savedDraftsOnly()
    .draftCreator(currentUser)
    .orderBy('elements.dateUpdated DESC')
    .one() %}
{% endif %}
{% if not transitionHomeEntry %}
  {% set transitionHomeEntry = craft.entries().section('homepage').site(currentSite).one() %}
{% endif %}
{% set transitionHoleTop = transitionHomeEntry and transitionHomeEntry.coverHoleTop ? transitionHomeEntry.coverHoleTop : '12vh' %}
{% set transitionHoleLeft = transitionHomeEntry and transitionHomeEntry.coverHoleLeft ? transitionHomeEntry.coverHoleLeft : '55vw' %}
{% set transitionHoleSize = transitionHomeEntry and transitionHomeEntry.coverHoleSizeWidth ? transitionHomeEntry.coverHoleSizeWidth : '18vw' %}
{% set pageBodyClass %}{% block bodyClass %}{% endblock %}{% endset %}
{% set navTheme %}{% block navTheme %}black{% endblock %}{% endset %}
{% set navLayout %}{% block navLayout %}full{% endblock %}{% endset %}
{% set navBehavior %}{% block navBehavior %}static{% endblock %}{% endset %}
<head>
    <meta charset="utf-8">
    <title>{% block title %}{{ siteName }}{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
      (function() {
        try {
          var raw = window.sessionStorage.getItem("site-page-transition");

          if (!raw) {
            return;
          }

          var parsed = JSON.parse(raw);

          if (!parsed || !parsed.ts || (Date.now() - parsed.ts) > 15000) {
            window.sessionStorage.removeItem("site-page-transition");
            return;
          }

          document.documentElement.classList.add("has-page-transition-enter");
        } catch (error) {
          return;
        }
      })();
    </script>
    <link rel="stylesheet" href="/css/base/variables.css">
    <link rel="stylesheet" href="/css/base/reset.css">
    <link rel="stylesheet" href="/css/base/base.css?v=1">
    <link rel="stylesheet" href="/css/base/typography.css">
    <link rel="stylesheet" href="/css/nav/nav.css?v=23">
    <link rel="stylesheet" href="/css/info/info.css?v=1">
    <link rel="stylesheet" href="/css/contact/contact.css?v=1">
    <link rel="stylesheet" href="/css/legal/legal.css?v=1">
    <link rel="stylesheet" href="/css/transition/transition.css?v=4">
    <link rel="stylesheet" href="/css/styles.css?v=2">
    {% block pageStyles %}{% endblock %}
</head>
<body
  class="{{ pageBodyClass|trim }}"
  style="--page-transition-hole-top: {{ transitionHoleTop|e('html_attr') }}; --page-transition-hole-left: {{ transitionHoleLeft|e('html_attr') }}; --page-transition-hole-size: {{ transitionHoleSize|e('html_attr') }};"
>
    {% include "_components/shared/nav/nav.twig" with {
      navLayout: navLayout|trim ?: 'full',
      navTheme: navTheme|trim ?: 'black',
      navBehavior: navBehavior|trim ?: 'static'
    } %}

    <main class="site-main">
        {% block content %}{% endblock %}
    </main>

    <div class="page-transition" aria-hidden="true">
      <div class="page-transition__window"></div>
    </div>

    <script src="/js/vendor/gsap.min.js"></script>
    <script src="/js/scripts.js?v=7"></script>
    {% block pageScripts %}{% endblock %}
    <script src="/js/transition/pageTransition.js?v=14"></script>
</body>
</html>
